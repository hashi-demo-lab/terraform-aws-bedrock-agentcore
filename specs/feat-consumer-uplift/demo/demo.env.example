# ─── Demo Configuration ───────────────────────────────────────────────────────
# Copy to demo.env and fill in values:
#   cp demo.env.example demo.env
#
# These values are used by setup.sh, publish-module-version.sh,
# trigger-bump.sh, and teardown.sh

# ─── HCP Terraform ───────────────────────────────────────────────────────────
TFE_ORG="hashi-demos-apj"
TFE_PROJECT="sandbox"
TFE_HOSTNAME="app.terraform.io"

# Workspace name — auto-generated if empty (uses repo name)
# TFE_WORKSPACE=""

# ─── GitHub ──────────────────────────────────────────────────────────────────
# The demo repo created by create-demo-repos.zsh
# Auto-detected from git remote if not set
# GITHUB_REPO="owner/repo-name"

# Base branch — the branch that has the workflow files and consumer code.
BASE_BRANCH="main"

# ─── Module Selection ────────────────────────────────────────────────────────
# Which PMR module to use for the demo
MODULE_NAME="s3-bucket"
MODULE_SOURCE="app.terraform.io/hashi-demos-apj/s3-bucket/aws"
MODULE_CURRENT_VERSION="5.8.2"

# Target version for the bump (auto-set by publish-module-version.sh)
# Must differ from MODULE_CURRENT_VERSION before running trigger-bump.sh
MODULE_TARGET_VERSION="5.8.2"

# ─── Module Source Repository ────────────────────────────────────────────────
# VCS-connected repo that TFC watches for tags to publish new PMR versions.
# publish-module-version.sh creates git tags here to trigger TFC ingestion.
# teardown.sh cleans up demo tags from this repo.
MODULE_SOURCE_REPO="hashi-demo-lab/terraform-aws-s3-bucket"
MODULE_SOURCE_BRANCH="master"

# ─── AWS Region ──────────────────────────────────────────────────────────────
AWS_REGION="ap-southeast-2"

# ─── Demo Scenario ───────────────────────────────────────────────────────────
# Which pipeline path to demonstrate:
#   patch    — adds a tag alongside bump (exit 2 → adds only, risk:low, needs-review)
#   minor    — adds logging config (exit 2 → changes to existing, risk:medium, needs-review)
#   breaking — introduces error that fails plan (exit 1 → breaking-change path)
#   no-op    — version already applied (exit 0 → auto-close PR path)
DEMO_SCENARIO="patch"
